# Stentorian Guard developer tooling.
# Install with: brew bundle

# Lint GitHub Actions workflow syntax locally.
brew "actionlint"

# Linux parity checks run in containers from pre-commit and pre-push.
brew "colima"
brew "docker"

# Conventional-commits changelog generator (cliff.toml).
brew "git-cliff"

# JSON processing for feed updates and workflow scripts.
brew "jq"

# Node — drives `npx markdownlint-cli2` from the pre-commit hook.
brew "node"

# Shell script linting for workflow helper scripts.
brew "shellcheck"
