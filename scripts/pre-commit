#!/usr/bin/env bash
#
# Pre-commit hook for Stentorian Guard.
# Install: ./scripts/install-hooks.sh
#
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
source "$REPO_ROOT/scripts/check-cache.sh"

RED='\033[0;31m'
GREEN='\033[0;32m'
BOLD='\033[1m'
RESET='\033[0m'

fail() {
  echo -e "${RED}${BOLD}pre-commit: $1${RESET}" >&2
  exit 1
}

pass() {
  echo -e "${GREEN}✓${RESET} $1"
}

skip() {
  echo -e "${GREEN}✓${RESET} $1 ${BOLD}(cached)${RESET}"
}

cache_prune

branch_scan_base() {
  git merge-base --fork-point '@{upstream}' HEAD 2>/dev/null \
    || git merge-base origin/main HEAD 2>/dev/null \
    || git merge-base main HEAD 2>/dev/null
}

# ── 0. Skip build/test when only repo-meta files changed ────────────────────
REPO_META_ONLY=0
if changes_only_repo_meta staged; then
  REPO_META_ONLY=1
fi

# ── 1. Secret scan ──────────────────────────────────────────────────────────
#
# CI scans only commits added by the PR branch. Mirror that locally instead of
# scanning the entire repository history, and also scan the staged patch because
# the commit being created is not reachable from HEAD yet.
if ! command -v trufflehog &>/dev/null; then
  fail "trufflehog not found — install with 'brew install trufflehog'"
fi

scan_base=$(branch_scan_base) \
  || fail "could not determine branch base for secret scan"

if [ -n "$(git rev-list --max-count=1 "$scan_base..HEAD")" ]; then
  trufflehog git "file://$REPO_ROOT" \
    --since-commit "$scan_base" \
    --branch HEAD \
    --results=verified \
    --fail \
    --no-update \
    || fail "secret scan failed for commits added on this branch"
fi

staged_patch=$(mktemp)
trap 'rm -f "$staged_patch"' EXIT
git diff --cached --binary > "$staged_patch"
if [ -s "$staged_patch" ]; then
  trufflehog filesystem "$staged_patch" \
    --results=verified \
    --fail \
    --no-update \
    || fail "secret scan failed for staged changes"
fi
pass "secret scan"

# ── 2. Reject Co-Authored-By lines ──────────────────────────────────────────
#
# Check the staged diff for Co-Authored-By trailers. The commit message isn't
# available yet in a pre-commit hook, so we check it via the prepare-commit-msg
# or commit-msg hook instead — but we CAN check that no staged file content
# contains it (e.g. pasted into source).
#
# For the commit message itself, we install a companion commit-msg check below.

# ── 3. Markdown lint ────────────────────────────────────────────────────────
if command -v npx &>/dev/null; then
  MD_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.md' || true)
  if [ -n "$MD_FILES" ]; then
    fp=$(staged_md_fingerprint)
    if cache_hit "pre-commit:mdlint" "$fp"; then
      skip "markdown lint"
    else
      echo "$MD_FILES" | xargs npx --yes markdownlint-cli2 \
        || fail "markdown lint failed"
      cache_mark "pre-commit:mdlint" "$fp"
      pass "markdown lint"
    fi
  fi
else
  echo "⚠ npx not found — skipping markdown lint"
fi

# ── 4–6. Cargo check / machete / test — skip when only repo-meta changed ────
if [ "$REPO_META_ONLY" -eq 1 ]; then
  skip "cargo check, machete, test (repo-meta-only change)"
else
  # ── 4. Cargo check (fast type/borrow check, no codegen) ───────────────────
  fp=$(rust_fingerprint)
  if cache_hit "pre-commit:cargo-check" "$fp"; then
    skip "cargo check"
  else
    cargo check --workspace --quiet \
      || fail "cargo check failed"
    cache_mark "pre-commit:cargo-check" "$fp"
    pass "cargo check"
  fi

  # ── 5. Unused dependency lint (cargo-machete — stable, no compilation) ────
  if cache_hit "pre-commit:machete" "$fp"; then
    skip "cargo machete"
  else
    if command -v cargo-machete &>/dev/null; then
      cargo machete --with-metadata \
        || fail "cargo machete found unused dependencies"
      cache_mark "pre-commit:machete" "$fp"
      pass "cargo machete"
    else
      echo "⚠ cargo-machete not found — skipping (cargo install cargo-machete)"
    fi
  fi

  # ── 6. Cargo test — unit + integration tests (excludes E2E) ───────────────
  if cache_hit "pre-commit:cargo-test" "$fp"; then
    skip "cargo test (unit + integration, E2E skipped)"
  else
    cargo test --workspace --exclude guard-e2e --quiet \
      || fail "cargo test failed"
    cache_mark "pre-commit:cargo-test" "$fp"
    pass "cargo test (unit + integration, E2E skipped)"
  fi
fi

echo -e "\n${GREEN}${BOLD}All pre-commit checks passed.${RESET}"
