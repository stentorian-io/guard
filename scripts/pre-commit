#!/usr/bin/env bash
#
# Pre-commit hook for Sentinel.
# Install: ./scripts/install-hooks.sh
#
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
BOLD='\033[1m'
RESET='\033[0m'

fail() {
  echo -e "${RED}${BOLD}pre-commit: $1${RESET}" >&2
  exit 1
}

pass() {
  echo -e "${GREEN}✓${RESET} $1"
}

# ── 1. Reject Co-Authored-By lines ──────────────────────────────────────────
#
# Check the staged diff for Co-Authored-By trailers. The commit message isn't
# available yet in a pre-commit hook, so we check it via the prepare-commit-msg
# or commit-msg hook instead — but we CAN check that no staged file content
# contains it (e.g. pasted into source).
#
# For the commit message itself, we install a companion commit-msg check below.

# ── 2. Markdown lint ────────────────────────────────────────────────────────
if command -v npx &>/dev/null; then
  # Only lint staged .md files
  MD_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.md' || true)
  if [ -n "$MD_FILES" ]; then
    echo "$MD_FILES" | xargs npx --yes markdownlint-cli2 \
      || fail "markdown lint failed"
    pass "markdown lint"
  fi
else
  echo "⚠ npx not found — skipping markdown lint"
fi

# ── 3. Cargo check (fast type/borrow check, no codegen) ─────────────────────
cargo check --workspace --quiet \
  || fail "cargo check failed"
pass "cargo check"

# ── 4. Cargo test — unit + integration tests (excludes E2E) ─────────────────
cargo test --workspace --exclude sentinel-e2e --quiet \
  || fail "cargo test failed"
pass "cargo test (unit + integration, E2E skipped)"

echo -e "\n${GREEN}${BOLD}All pre-commit checks passed.${RESET}"
