#!/usr/bin/env bash
#
# Pre-commit hook for Stentorian Guard.
# Install: ./scripts/install-hooks.sh
#
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
source "$REPO_ROOT/scripts/check-cache.sh"

RED='\033[0;31m'
GREEN='\033[0;32m'
BOLD='\033[1m'
RESET='\033[0m'

fail() {
  echo -e "${RED}${BOLD}pre-commit: $1${RESET}" >&2
  exit 1
}

pass() {
  echo -e "${GREEN}✓${RESET} $1"
}

skip() {
  echo -e "${GREEN}✓${RESET} $1 ${BOLD}(cached)${RESET}"
}

cache_prune

branch_scan_base() {
  git merge-base --fork-point '@{upstream}' HEAD 2>/dev/null \
    || git merge-base origin/main HEAD 2>/dev/null \
    || git merge-base main HEAD 2>/dev/null
}

# ── 0. Skip build/test when only repo-meta files changed ────────────────────
REPO_META_ONLY=0
if changes_only_repo_meta staged; then
  REPO_META_ONLY=1
fi

# ── 1. Reject Co-Authored-By lines ──────────────────────────────────────────
#
# Check the staged diff for Co-Authored-By trailers. The commit message isn't
# available yet in a pre-commit hook, so we check it via the prepare-commit-msg
# or commit-msg hook instead — but we CAN check that no staged file content
# contains it (e.g. pasted into source).
#
# For the commit message itself, we install a companion commit-msg check below.

# ── 2. Markdown lint ────────────────────────────────────────────────────────
NODE_BIN="$(command -v node || true)"
if [ -x /opt/homebrew/bin/node ]; then
  NODE_BIN=/opt/homebrew/bin/node
fi
if [ -x /opt/homebrew/opt/node@20/bin/node ]; then
  NODE_BIN=/opt/homebrew/opt/node@20/bin/node
fi
if [ -n "$NODE_BIN" ] && [ -x "$(dirname "$NODE_BIN")/npx" ]; then
  MD_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.md' || true)
  if [ -n "$MD_FILES" ]; then
    fp=$(staged_md_fingerprint)
    if cache_hit "pre-commit:mdlint" "$fp"; then
      skip "markdown lint"
    else
      echo "$MD_FILES" | PATH="$(dirname "$NODE_BIN"):$PATH" xargs npx --yes markdownlint-cli2 \
        || fail "markdown lint failed"
      cache_mark "pre-commit:mdlint" "$fp"
      pass "markdown lint"
    fi
  fi
else
  echo "⚠ node/npx not found — skipping markdown lint"
fi

# ── 3–7. Cheap validation — skip when only repo-meta changed ────────────────
if [ "$REPO_META_ONLY" -eq 1 ]; then
  skip "cargo check, machete, build, test (repo-meta-only change)"
else
  # ── 3. Cargo check (fast type/borrow check, no codegen) ───────────────────
  fp=$(rust_fingerprint)
  if cache_hit "pre-commit:cargo-check" "$fp"; then
    skip "cargo check"
  else
    cargo check --workspace --quiet \
      || fail "cargo check failed"
    cache_mark "pre-commit:cargo-check" "$fp"
    pass "cargo check"
  fi

  # ── 4. Unused dependency lint (cargo-machete — stable, no compilation) ────
  if cache_hit "pre-commit:machete" "$fp"; then
    skip "cargo machete"
  else
    if command -v cargo-machete &>/dev/null; then
      cargo machete --with-metadata \
        || fail "cargo machete found unused dependencies"
      cache_mark "pre-commit:machete" "$fp"
      pass "cargo machete"
    else
      echo "⚠ cargo-machete not found — skipping (cargo install cargo-machete)"
    fi
  fi

  # ── 5. Release build — catches workspace build failures before push ───────
  if cache_hit "pre-commit:cargo-build-release" "$fp"; then
    skip "cargo build --workspace --release"
  else
    cargo build --workspace --release \
      || fail "cargo build --workspace --release failed"
    cache_mark "pre-commit:cargo-build-release" "$fp"
    pass "cargo build --workspace --release"
  fi

  # ── 6. Unit tests — no E2E ────────────────────────────────────────────────
  if cache_hit "pre-commit:cargo-test-unit" "$fp"; then
    skip "cargo test unit targets"
  else
    cargo test --workspace --exclude guard-e2e --lib --bins --quiet \
      || fail "cargo test unit targets failed"
    cache_mark "pre-commit:cargo-test-unit" "$fp"
    pass "cargo test unit targets"
  fi

  # ── 7. Integration tests — no E2E ─────────────────────────────────────────
  if cache_hit "pre-commit:cargo-test-integration" "$fp"; then
    skip "cargo test integration targets"
  else
    cargo test --workspace --exclude guard-e2e --tests --quiet \
      || fail "cargo test integration targets failed"
    cache_mark "pre-commit:cargo-test-integration" "$fp"
    pass "cargo test integration targets"
  fi
fi

echo -e "\n${GREEN}${BOLD}All pre-commit checks passed.${RESET}"
