#!/usr/bin/env bash
#
# Pre-commit hook for Stentorian Guard.
# Install: ./scripts/install-hooks.sh
#
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
if [ -f "$HOME/.cargo/env" ]; then
  # shellcheck disable=SC1091
  . "$HOME/.cargo/env"
fi
export PATH="$HOME/.cargo/bin:/opt/homebrew/opt/rustup/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

source "$REPO_ROOT/scripts/check-cache.sh"

RED='\033[0;31m'
GREEN='\033[0;32m'
BOLD='\033[1m'
RESET='\033[0m'

fail() {
  echo -e "${RED}${BOLD}pre-commit: $1${RESET}" >&2
  exit 1
}

pass() {
  echo -e "${GREEN}✓${RESET} $1"
}

warn() {
  echo "⚠ $1"
}

skip() {
  echo -e "${GREEN}✓${RESET} $1 ${BOLD}(cached)${RESET}"
}

cache_prune

branch_scan_base() {
  git merge-base --fork-point '@{upstream}' HEAD 2>/dev/null \
    || git merge-base origin/main HEAD 2>/dev/null \
    || git merge-base main HEAD 2>/dev/null
}

# ── 0. Skip build/test when only repo-meta files changed ────────────────────
REPO_META_ONLY=0
if changes_only_repo_meta staged; then
  REPO_META_ONLY=1
fi

# ── 1. Reject Co-Authored-By lines ──────────────────────────────────────────
#
# Check the staged diff for Co-Authored-By trailers. The commit message isn't
# available yet in a pre-commit hook, so we check it via the prepare-commit-msg
# or commit-msg hook instead — but we CAN check that no staged file content
# contains it (e.g. pasted into source).
#
# For the commit message itself, we install a companion commit-msg check below.

# ── 2. Markdown lint ────────────────────────────────────────────────────────
if command -v bunx >/dev/null; then
  MD_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.md' || true)
  if [ -n "$MD_FILES" ]; then
    fp=$(staged_md_fingerprint)
    if cache_hit "pre-commit:mdlint" "$fp"; then
      skip "markdown lint"
    else
      echo "$MD_FILES" | TMPDIR="${TMPDIR:-/private/tmp}" xargs bunx markdownlint-cli2 \
        || fail "markdown lint failed"
      cache_mark "pre-commit:mdlint" "$fp"
      pass "markdown lint"
    fi
  fi
else
  echo "⚠ bunx not found — skipping markdown lint"
fi

# ── 3. GitHub Actions lint ─────────────────────────────────────────────────
WORKFLOW_FILES=$(git diff --cached --name-only --diff-filter=ACM -- \
  '.github/workflows/*.yml' \
  '.github/workflows/*.yaml' || true)
if [ -n "$WORKFLOW_FILES" ]; then
  if command -v actionlint &>/dev/null; then
    actionlint \
      || fail "GitHub Actions workflow lint failed"
    pass "GitHub Actions workflow lint"
  else
    fail "actionlint not found; install it locally (for example: brew install actionlint)"
  fi
fi

# ── 3a. Bash syntax lint ───────────────────────────────────────────────────
SHELL_FILES=$(git diff --cached --name-only --diff-filter=ACM -- \
  'scripts/*.sh' \
  'tools/*.sh' \
  'scripts/pre-commit' \
  'scripts/pre-push' \
  'scripts/commit-msg' \
  'scripts/prepare-commit-msg' \
  'scripts/validate-conventional-subject' \
  'install.sh' \
  'uninstall.sh' || true)
if [ -n "$SHELL_FILES" ]; then
  echo "$SHELL_FILES" | xargs bash -n \
    || fail "bash syntax lint failed"
  pass "bash syntax lint"
fi

# ── 3b. Optional secret scan ───────────────────────────────────────────────
if [ "${STT_GUARD_PRE_COMMIT_SECRET_SCAN:-0}" = "1" ]; then
  scan_base="$(branch_scan_base)"
  if command -v trufflehog &>/dev/null; then
    trufflehog git "file://$REPO_ROOT" \
      --since-commit "$scan_base" \
      --branch HEAD \
      --only-verified \
      --fail \
      || fail "secret scan failed"
    pass "secret scan"
  else
    fail "trufflehog not found; install it or unset STT_GUARD_PRE_COMMIT_SECRET_SCAN"
  fi
else
  warn "skipping secret scan (set STT_GUARD_PRE_COMMIT_SECRET_SCAN=1 to run)"
fi

# ── 3c. Optional dependency CVE audit ──────────────────────────────────────
if [ "${STT_GUARD_PRE_COMMIT_CVE_AUDIT:-0}" = "1" ]; then
  if command -v cargo-audit &>/dev/null; then
    cargo audit \
      || fail "dependency CVE audit failed"
    pass "dependency CVE audit"
  else
    fail "cargo-audit not found; install it or unset STT_GUARD_PRE_COMMIT_CVE_AUDIT"
  fi
else
  warn "skipping dependency CVE audit (set STT_GUARD_PRE_COMMIT_CVE_AUDIT=1 to run)"
fi

# ── 4–8. Cheap validation — skip when only repo-meta changed ────────────────
if [ "$REPO_META_ONLY" -eq 1 ]; then
  skip "cargo check, machete, build, test (repo-meta-only change)"
else
  # ── 4. Cargo check (fast type/borrow check, no codegen) ───────────────────
  fp=$(rust_fingerprint)
  if cache_hit "pre-commit:rustfmt-clippy" "$fp"; then
    skip "cargo fmt and clippy"
  else
    before_autofix="$(mktemp)"
    after_autofix="$(mktemp)"
    git diff --binary HEAD > "$before_autofix"

    cargo fmt \
      || fail "cargo fmt failed"
    cargo clippy --fix --workspace --all-targets --allow-dirty --allow-staged --quiet -- -D warnings \
      || fail "cargo clippy --fix failed"

    git diff --binary HEAD > "$after_autofix"
    if ! cmp -s "$before_autofix" "$after_autofix"; then
      rm -f "$before_autofix" "$after_autofix"
      fail "rustfmt/clippy applied fixes; review them, stage the updates, and commit again"
    fi
    rm -f "$before_autofix" "$after_autofix"

    cargo fmt --check \
      || fail "cargo fmt --check failed"
    cargo clippy --workspace --all-targets -- -D warnings \
      || fail "cargo clippy failed"
    cache_mark "pre-commit:rustfmt-clippy" "$fp"
    pass "cargo fmt and clippy"
  fi

  scripts/lint-test-env-vars.sh \
    || fail "test env var hygiene failed"
  pass "test env var hygiene"

  linux_check_fp=$(linux_ci_check_fingerprint)
  if cache_hit "pre-commit:linux-check" "$linux_check_fp"; then
    skip "Linux check"
  else
    bash scripts/ci-linux-check.sh \
      || fail "Linux check failed"
    cache_mark "pre-commit:linux-check" "$linux_check_fp"
    pass "Linux check"
  fi

  linux_fp=$(linux_ci_lint_fingerprint)
  if cache_hit "pre-commit:linux-ci-lint" "$linux_fp"; then
    skip "Linux CI rustfmt/clippy"
  else
    scripts/ci-linux-lint.sh \
      || fail "Linux CI rustfmt/clippy failed"
    cache_mark "pre-commit:linux-ci-lint" "$linux_fp"
    pass "Linux CI rustfmt/clippy"
  fi

  if cache_hit "pre-commit:cargo-check" "$fp"; then
    skip "cargo check"
  else
    cargo check --workspace --quiet \
      || fail "cargo check failed"
    cache_mark "pre-commit:cargo-check" "$fp"
    pass "cargo check"
  fi

  # ── 5. Unused dependency lint (cargo-machete — stable, no compilation) ────
  if cache_hit "pre-commit:machete" "$fp"; then
    skip "cargo machete"
  else
    if command -v cargo-machete &>/dev/null; then
      cargo machete --with-metadata \
        || fail "cargo machete found unused dependencies"
      cache_mark "pre-commit:machete" "$fp"
      pass "cargo machete"
    else
      echo "⚠ cargo-machete not found — skipping (cargo install cargo-machete)"
    fi
  fi

  # ── 6. Release builds — catch platform artifact failures before push ──────
  if cache_hit "pre-commit:cargo-build-release" "$fp"; then
    skip "cargo build --workspace --release"
  else
    cargo build --workspace --release \
      || fail "cargo build --workspace --release failed"
    cache_mark "pre-commit:cargo-build-release" "$fp"
    pass "cargo build --workspace --release"
  fi

  linux_release_fp=$(linux_ci_release_build_fingerprint)
  if cache_hit "pre-commit:linux-release-build" "$linux_release_fp"; then
    skip "Linux release build"
  else
    bash scripts/ci-linux-release-build.sh \
      || fail "Linux release build failed"
    cache_mark "pre-commit:linux-release-build" "$linux_release_fp"
    pass "Linux release build"
  fi

  # ── 7. Unit tests — no E2E ────────────────────────────────────────────────
  if cache_hit "pre-commit:cargo-test-unit" "$fp"; then
    skip "cargo test unit targets"
  else
    cargo test --workspace --exclude guard-e2e --lib --bins --quiet \
      || fail "cargo test unit targets failed"
    cache_mark "pre-commit:cargo-test-unit" "$fp"
    pass "cargo test unit targets"
  fi

  # ── 8. Integration tests — no E2E ─────────────────────────────────────────
  if cache_hit "pre-commit:cargo-test-integration" "$fp"; then
    skip "cargo test integration targets"
  else
    cargo test --workspace --exclude guard-e2e --tests --quiet \
      || fail "cargo test integration targets failed"
    cache_mark "pre-commit:cargo-test-integration" "$fp"
    pass "cargo test integration targets"
  fi
fi

echo -e "\n${GREEN}${BOLD}All pre-commit checks passed.${RESET}"
