#!/usr/bin/env bash
#
# Pre-push hook for Stentorian Guard.
# Install: ./scripts/install-hooks.sh
#
# Pre-commit owns lint, build, unit tests, and integration tests. Pre-push
# re-checks Linux parity through the shared cache, then runs platform E2E tests.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"
source "$REPO_ROOT/scripts/check-cache.sh"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BOLD='\033[1m'
RESET='\033[0m'

fail() {
  echo -e "${RED}${BOLD}pre-push: $1${RESET}" >&2
  exit 1
}

pass() {
  echo -e "${GREEN}✓${RESET} $1"
}

warn() {
  echo -e "${YELLOW}⚠${RESET} $1"
}

changed_files_for_push() {
  local remote_name="$1"
  local push_refs="$2"
  local zero_sha="0000000000000000000000000000000000000000"
  local changed_files=""

  while read -r local_ref local_sha _remote_ref remote_sha; do
    [ -n "${local_ref:-}" ] || continue
    [ "$local_sha" != "$zero_sha" ] || continue

    local base_ref
    if [ "$remote_sha" = "$zero_sha" ]; then
      base_ref=$(
        git merge-base "$local_sha" "$remote_name/main" 2>/dev/null \
          || git merge-base "$local_sha" origin/main 2>/dev/null \
          || git merge-base "$local_sha" main 2>/dev/null \
          || git rev-parse "$local_sha^" 2>/dev/null
      )
    else
      base_ref="$remote_sha"
    fi

    changed_files+=$'\n'
    changed_files+="$(git diff --name-only "$base_ref" "$local_sha")"
  done <<< "$push_refs"

  printf '%s\n' "$changed_files" | sed '/^$/d' | sort -u
}

branch_scan_base() {
  git merge-base --fork-point '@{upstream}' HEAD 2>/dev/null \
    || git merge-base origin/main HEAD 2>/dev/null \
    || git merge-base main HEAD 2>/dev/null
}

run_e2e() {
  local test_name="$1"
  local label="$2"
  cargo test -p guard-e2e --features test-signer --test "$test_name" --release -- --nocapture \
    || fail "$label"
  pass "$label"
}

run_hot_path_benchmark() {
  if [ "$(uname -s)" != "Darwin" ]; then
    warn "skipping hot-path benchmark (macOS-only)"
    return
  fi

  mkdir -p target/bench-hot-path
  ./scripts/bench-hot-path.sh \
    --cache-hit-only \
    --enforce-cache-hit-budget \
    --github-action-benchmark-json target/bench-hot-path/pre-push-github-action-benchmark.json \
    || fail "hot-path benchmark"
  pass "hot-path benchmark"
}

PUSH_REFS="$(cat)"
PUSH_CHANGED_FILES="$(changed_files_for_push "${1:-origin}" "$PUSH_REFS")"

scripts/lint-test-env-vars.sh \
  || fail "test env var hygiene failed"
pass "test env var hygiene"

if [ "${STT_GUARD_PRE_PUSH_SECRET_SCAN:-0}" = "1" ]; then
  scan_base="$(branch_scan_base)"
  if command -v trufflehog &>/dev/null; then
    trufflehog git "file://$REPO_ROOT" \
      --since-commit "$scan_base" \
      --branch HEAD \
      --only-verified \
      --fail \
      || fail "secret scan failed"
    pass "secret scan"
  else
    fail "trufflehog not found; install it or unset STT_GUARD_PRE_PUSH_SECRET_SCAN"
  fi
else
  warn "skipping secret scan (set STT_GUARD_PRE_PUSH_SECRET_SCAN=1 to run)"
fi

if [ "${STT_GUARD_PRE_PUSH_CVE_AUDIT:-0}" = "1" ]; then
  if command -v cargo-audit &>/dev/null; then
    cargo audit \
      || fail "dependency CVE audit failed"
    pass "dependency CVE audit"
  else
    fail "cargo-audit not found; install it or unset STT_GUARD_PRE_PUSH_CVE_AUDIT"
  fi
else
  warn "skipping dependency CVE audit (set STT_GUARD_PRE_PUSH_CVE_AUDIT=1 to run)"
fi

if [ -n "$PUSH_CHANGED_FILES" ] && ! changes_affect_e2e_files "$PUSH_CHANGED_FILES"; then
  pass "skipping pre-push runtime checks (no E2E-relevant files changed)"
  exit 0
fi

cache_prune
linux_fp=$(linux_ci_lint_fingerprint)
if cache_hit "pre-push:linux-ci-lint" "$linux_fp" || cache_hit "pre-commit:linux-ci-lint" "$linux_fp"; then
  pass "Linux CI rustfmt/clippy (cached)"
else
  scripts/ci-linux-lint.sh \
    || fail "Linux CI rustfmt/clippy"
  cache_mark "pre-push:linux-ci-lint" "$linux_fp"
  pass "Linux CI rustfmt/clippy"
fi

scripts/ci-linux-e2e.sh \
  || fail "Linux E2E LD_PRELOAD smoke"
pass "Linux E2E LD_PRELOAD smoke"

cargo build -p guard-cli -p guard-daemon -p guard-hook --release --features test-signer \
  || fail "build release binaries with test signer"
pass "build release binaries with test signer"

run_e2e ua_parser_js_demo "VAL-01 ua-parser-js@0.7.29 demo"
run_e2e workers_dev_validation "VAL-02 workers.dev allowlist-bleed"
run_e2e failure_modes_corrupt_snapshot "VAL-04 D-12 corrupt snapshot"
run_e2e failure_modes_hardened_exec "VAL-04 D-10 hardened-binary exec gap"

if [ "${STT_GUARD_PRE_PUSH_RUN_PRIVILEGED:-0}" = "1" ]; then
  STT_GUARD_E2E_PRIVILEGED_INSTALL=1 \
    cargo test -p guard-e2e --features test-signer --test hardened_install_health --release -- --nocapture \
    || fail "VAL-05 privileged init and install health"
  pass "VAL-05 privileged init and install health"
else
  warn "skipping VAL-05 privileged init and install health (set STT_GUARD_PRE_PUSH_RUN_PRIVILEGED=1 to run)"
fi

run_hot_path_benchmark

echo -e "\n${GREEN}${BOLD}All pre-push E2E checks passed.${RESET}"
