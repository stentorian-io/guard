#!/usr/bin/env bash
#
# prepare-commit-msg hook: inspects staged files to suggest/auto-correct
# the conventional commit type before the message is finalized.
# Install: ./scripts/install-hooks.sh
#
set -euo pipefail

MSG_FILE="$1"
MSG_SOURCE="${2:-}"

# Only act on user-authored messages (-m flag or editor).
# Skip merge commits, squash commits, and template-sourced messages.
case "$MSG_SOURCE" in
  merge|squash) exit 0 ;;
esac

# ── Classify staged files ──────────────────────────────────────────────────

STAGED=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)
[ -z "$STAGED" ] && exit 0

has_src=false
has_test=false
has_ci=false
has_doc=false
has_build=false

while IFS= read -r f; do
  case "$f" in
    .github/workflows/*|.github/actions/*)
      has_ci=true ;;
    crates/sentinel-e2e/tests/*|crates/*/tests/*|*/tests/*)
      has_test=true ;;
    crates/sentinel-e2e/harness/*|crates/sentinel-e2e/fixtures/*)
      has_test=true ;;
    Cargo.toml|crates/*/Cargo.toml|Cargo.lock|rust-toolchain.toml)
      has_build=true ;;
    *.rs)
      has_src=true ;;
    docs/*|*.md)
      has_doc=true ;;
    cliff.toml|.markdownlint*|.actrc|Brewfile|.gitignore|.github/CODEOWNERS)
      has_build=true ;;
    scripts/*)
      has_build=true ;;
  esac
done <<< "$STAGED"

# ── Infer the best commit type from staged files ──────────────────────────

infer_type() {
  if $has_src && ! $has_test && ! $has_ci; then
    echo "feat or fix"
  elif $has_test && ! $has_src; then
    echo "test"
  elif $has_ci && ! $has_src; then
    echo "ci"
  elif $has_doc && ! $has_src && ! $has_test && ! $has_ci; then
    echo "docs"
  elif $has_build && ! $has_src && ! $has_test && ! $has_ci; then
    echo "chore or build"
  elif $has_src && $has_test; then
    echo "feat or fix (with tests)"
  else
    echo "unclear"
  fi
}

INFERRED=$(infer_type)

# ── Read current message type (if any) ─────────────────────────────────────

FIRST_LINE=$(head -1 "$MSG_FILE")
CURRENT_TYPE=""
if echo "$FIRST_LINE" | grep -Eq '^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?!?: .+'; then
  CURRENT_TYPE=$(echo "$FIRST_LINE" | sed -E 's/^([a-z]+).*/\1/')
fi

# ── Auto-correct obvious mismatches ────────────────────────────────────────

if [ -n "$CURRENT_TYPE" ]; then
  REWRITE=""

  # feat/fix but only docs/markdown changed → chore or docs
  if [[ "$CURRENT_TYPE" =~ ^(feat|fix)$ ]] && $has_doc && ! $has_src && ! $has_test && ! $has_ci; then
    REWRITE="docs"
  fi

  # feat/fix but only test files changed → test
  if [[ "$CURRENT_TYPE" =~ ^(feat|fix)$ ]] && $has_test && ! $has_src && ! $has_ci && ! $has_doc; then
    REWRITE="test"
  fi

  # feat/fix but only CI files changed → ci
  if [[ "$CURRENT_TYPE" =~ ^(feat|fix)$ ]] && $has_ci && ! $has_src && ! $has_test && ! $has_doc; then
    REWRITE="ci"
  fi

  # feat/fix but only build/config files changed → chore
  if [[ "$CURRENT_TYPE" =~ ^(feat|fix)$ ]] && $has_build && ! $has_src && ! $has_test && ! $has_ci && ! $has_doc; then
    REWRITE="chore"
  fi

  # docs(bench|code|internal) → skip in changelog; suggest chore if not user-facing
  if [ "$CURRENT_TYPE" = "docs" ]; then
    SCOPE=$(echo "$FIRST_LINE" | sed -nE 's/^docs\(([^)]+)\).*/\1/p')
    case "$SCOPE" in
      man|help|install) ;; # shipped in release, keep
      bench|code|internal)
        # These will be skipped by cliff anyway, but note it
        ;;
    esac
  fi

  if [ -n "$REWRITE" ] && [ "$REWRITE" != "$CURRENT_TYPE" ]; then
    sed -i '' "s/^${CURRENT_TYPE}/${REWRITE}/" "$MSG_FILE"
    echo "prepare-commit-msg: rewritten type '${CURRENT_TYPE}' → '${REWRITE}' (staged files: ${INFERRED})" >&2
  fi
fi

# ── Inject guidance comments for editor-based commits ──────────────────────

# For -m messages, MSG_SOURCE is "message"; for editor, it's empty.
# Comments are stripped by git regardless, so safe to inject always.
if [ "$MSG_SOURCE" != "message" ] || [ -z "$CURRENT_TYPE" ]; then
  CHANGELOG_NOTE=""
  case "$INFERRED" in
    "test"|"ci"|"chore or build")
      CHANGELOG_NOTE="(will NOT appear in changelog)" ;;
    "docs")
      CHANGELOG_NOTE="(only docs(man|help|install) appear in changelog)" ;;
    *)
      CHANGELOG_NOTE="(will appear in changelog)" ;;
  esac

  {
    echo ""
    echo "# ── Commit type guidance ──────────────────────────────────────"
    echo "# Staged files suggest: ${INFERRED} ${CHANGELOG_NOTE}"
    echo "#"
    echo "# Changelog types: feat, fix, perf, docs(man|help|install)"
    echo "# Internal types:  test, refactor, chore, build, ci, docs(*)"
    echo "#"
    echo "# Rules enforced by commit-msg hook:"
    echo "#   feat/fix → must change source code (.rs), not just docs/tests/CI"
    echo "#   test     → must change test files"
    echo "#   ci       → must change .github/ files"
    echo "#   docs     → only (man|help|install) scopes reach changelog"
    echo "# ──────────────────────────────────────────────────────────────"
  } >> "$MSG_FILE"
fi
