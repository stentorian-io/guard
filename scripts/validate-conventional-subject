#!/usr/bin/env bash
set -euo pipefail

SUBJECT="${1:-}"

fail() {
  echo "validate-conventional-subject: $1" >&2
  exit 1
}

if [ -z "$SUBJECT" ]; then
  fail "subject is required"
fi

PATTERN='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([^)]+\))?!?: .+'
if ! grep -Eq "$PATTERN" <<< "$SUBJECT"; then
  fail "subject does not follow Conventional Commits.
Expected: <type>(<scope>): <description>
Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
Got: $SUBJECT"
fi

TYPE=$(sed -E 's/^([a-z]+).*/\1/' <<< "$SUBJECT")
SCOPE=$(sed -nE 's/^[a-z]+\(([^)]+)\).*/\1/p' <<< "$SUBJECT")
DESCRIPTION=$(sed -E 's/^[a-z]+(\([^)]+\))?!?: //' <<< "$SUBJECT")

if [ "$TYPE" = "docs" ]; then
  if [ -z "$SCOPE" ]; then
    fail "'docs' subjects require an explicit scope.
Allowed: docs(readme), docs(llm), docs(bench), docs(man), docs(help), docs(install)
Got: $SUBJECT"
  fi
  case "$SCOPE" in
    readme|llm|bench|man|help|install)
      ;;
    *)
      fail "docs(${SCOPE}) is not a recognized scope.
Allowed: readme, llm, bench, man, help, install
Changelog scopes: man, help, install"
      ;;
  esac
fi

if [ "$TYPE" = "ci" ] && [ -n "$SCOPE" ]; then
  fail "Scopes are not allowed for the 'ci' type. Use 'ci: ...' not 'ci(${SCOPE}): ...'"
fi

if grep -Eq '^[A-Z]' <<< "$DESCRIPTION"; then
  fail "description must start with a lowercase letter.
Got: $SUBJECT"
fi

if grep -Eq '\.$' <<< "$DESCRIPTION"; then
  fail "description must not end with a period.
Got: $SUBJECT"
fi
